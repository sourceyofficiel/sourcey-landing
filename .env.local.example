# ============================================================
# Creator Agency — variables d'environnement
# Copie ce fichier en .env.local et remplis chaque ligne.
# ============================================================

# --- Supabase (auth + DB) -----------------------------------
# Récupère ces 2 valeurs dans Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (admin) — SECRET, jamais côté client.
# Utile pour les routes serveur qui doivent bypasser RLS (ex: créer
# une invitation auth.users sans avoir l'user connecté).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Claude (analyse IA + drafts) ---------------------------
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Apify (scraping TikTok / Instagram) --------------------
# console.apify.com → Settings → Integrations → API token
APIFY_API_TOKEN=apify_api_...

# --- URL publique de l'app ---------------------------------
# Sert à construire les liens d'invitation et le redirect magic link
NEXT_PUBLIC_APP_URL=http://localhost:3000
