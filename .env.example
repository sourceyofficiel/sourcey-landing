# ============================================================
# REQUIRED — Database (Postgres)
# ============================================================
# Recommended: Neon (free tier, https://neon.tech) — same connection
# string works for both local dev and Vercel production.
DATABASE_URL="postgresql://[user]:[password]@[host].neon.tech/sourcey?sslmode=require"

# Other options :
# Supabase  : postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
# Vercel PG : postgres://[user]:[password]@[host].vercel-storage.com/[db]


# ============================================================
# REQUIRED in prod — Public site URL
# ============================================================
# Used by Stripe success/cancel URLs, magic links, emails…
NEXT_PUBLIC_SITE_URL="http://localhost:3000"


# ============================================================
# AUTHENTICATION — NextAuth v5
# ============================================================
# Generate with `openssl rand -base64 32`
NEXTAUTH_SECRET=""

# OAuth providers (optional) :
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""


# ============================================================
# AI — OpenAI (Visual Search, Brand Coach, translation, smart replies)
# ============================================================
# Without this, all AI features fall back to mocked deterministic responses
OPENAI_API_KEY=""
# Optional overrides
OPENAI_MODEL="gpt-4o-mini"
OPENAI_VISION_MODEL="gpt-4o"


# ============================================================
# EMAIL — Resend (transactional + magic links)
# ============================================================
# Without this, emails are only logged to the server console
RESEND_API_KEY=""
EMAIL_FROM="Sourcey <hello@yourdomain.com>"
EMAIL_REPLY_TO="hello@yourdomain.com"

# Where Entreprise leads are forwarded to your sales team
SALES_INBOX_EMAIL="enterprise@yourdomain.com"


# ============================================================
# PAYMENT — Stripe (subscriptions + one-off)
# ============================================================
# Without these, /pricing CTAs run in mock mode (no real charge)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Price IDs — create them in Stripe Dashboard > Products
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_STARTER_YEARLY=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""


# ============================================================
# ANALYTICS (optional)
# ============================================================
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
# If using GA4 instead :
# NEXT_PUBLIC_GA_ID=""


# ============================================================
# FILE UPLOADS — Vercel Blob (optional, for production storage)
# ============================================================
# Without this, uploads go to /public/uploads (only fine for local dev)
BLOB_READ_WRITE_TOKEN=""
