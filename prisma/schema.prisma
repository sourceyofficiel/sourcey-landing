generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// MARKETING / LANDING
// ============================================================

model Waitlist {
  id                    String   @id @default(cuid())
  email                 String   @unique
  source                String?
  accountTypeInterest   String?
  ecomPlatform          String?
  problemText           String?
  createdAt             DateTime @default(now())
}

model EnterpriseLead {
  id            String   @id @default(cuid())
  companyName   String
  contactName   String
  email         String
  phone         String?
  monthlyVolume String?
  budgetRange   String?
  categories    String?
  message       String?
  status        String   @default("new")
  createdAt     DateTime @default(now())
}

// ============================================================
// APP — USERS + MESSAGING
// ============================================================

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  passwordHash    String?                          // bcrypt hash — nullable for OAuth users
  fullName        String?
  whatsapp        String?                          // numéro WhatsApp (canal principal de comm)
  avatarUrl       String?
  companyName     String?
  phone           String?
  ecomPlatform    String?                          // 'shopify' | 'woocommerce' | 'prestashop' | 'amazon' | 'other' | 'none'
  monthlyVolume   String?                          // '<1k' | '1k-10k' | '10k-50k' | '50k+'
  bio             String?
  isAdmin         Boolean          @default(false) // accès au panel /admin
  plan            String           @default("free")
  // Stripe billing
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?   @unique
  subscriptionStatus    String?                    // 'active' | 'trialing' | 'past_due' | 'canceled' | 'incomplete'
  planRenewsAt          DateTime?                  // next billing date
  // ============================================================
  // AUTHENTIFICATION — sécurité, vérification, blocage
  // ============================================================
  emailVerifiedAt          DateTime?                // null = email pas encore vérifié (compte pas activé)
  disabledAt               DateTime?                // null = actif, sinon désactivé par admin
  failedLoginAttempts      Int      @default(0)     // compteur tentatives échec, reset à 0 après login OK
  lockedUntil              DateTime?                // null = pas bloqué, sinon timestamp fin blocage (15 min après 5 échecs)
  lastLoginAt              DateTime?
  lastLoginIpHash          String?                  // SHA-256 (jamais d'IP en clair, RGPD)

  // ============================================================
  // PROGRAMME D'AFFILIATION
  // ============================================================
  affiliateCode            String?  @unique         // code unique 8 chars alphanumériques (null = pas activé)
  affiliateActive          Boolean  @default(false) // false par défaut, true après /api/affiliate/activate
  affiliateSuspendedAt     DateTime?                // suspension anti-fraude (≥50 clics même IP / 24h)
  referredBy               String?                  // code affilié qui a parrainé ce user (immutable une fois posé)
  referredByIpHash         String?                  // hash SHA-256 de l'IP d'inscription (anti-fraude self-referral)
  stripeConnectAccountId   String?  @unique         // compte Stripe Connect Express pour recevoir les virements
  stripeConnectOnboarded   Boolean  @default(false) // true quand l'IBAN est renseigné côté Stripe

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  conversations   Conversation[]
  messages        Message[]
  serviceOrders   ServiceOrder[]
  productRequests ProductRequest[]
  briefs          Brief[]
  orders          Order[]
  affiliateCommissions  AffiliateCommission[] @relation("AffiliateCommissions")
  referredCommissions   AffiliateCommission[] @relation("ReferredCommissions")
  affiliatePayouts      AffiliatePayout[]
  oauthAccounts         OAuthAccount[]
  authTokens            AuthToken[]
  loginLogs             LoginLog[]
  autosavMemberships    AutosavWorkspaceMember[]
  autosavInvitations    AutosavInvitation[]       @relation("AutosavInvitedBy")
  autosavTicketReplies  AutosavTicketReply[]
  autosavAuditLogs      AutosavAuditLog[]

  @@index([referredBy])
}

// ============================================================
// AUTOSAV — SaaS de support client multi-tenant (sous-produit)
// Tout est préfixé Autosav* pour permettre une extraction propre vers
// un repo dédié quand le produit aura traction commerciale.
// ============================================================

model AutosavWorkspace {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  // Billing
  plan                 String   @default("trial")    // 'trial' | 'starter' | 'pro' | 'agency'
  trialEndsAt          DateTime?
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?
  subscriptionStatus   String?                       // 'active' | 'trialing' | 'past_due' | 'canceled'
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean  @default(false)
  // Quota (compteur mensuel)
  ticketsUsedThisMonth Int      @default(0)
  quotaLimit           Int      @default(200)
  quotaResetAt         DateTime @default(now())
  // Onboarding
  onboardingStep       Int      @default(0)          // 0..5, 5 = terminé
  onboardingDone       Boolean  @default(false)
  // Branding / IA
  signature            String   @default("Bonne journée,\nL'équipe")
  tone                 String   @default("friendly") // 'friendly' | 'pro' | 'casual'
  brandContext         String   @default("")
  kbText               String   @default("")         // Knowledge base en texte brut (RAG en phase 2)
  defaultLocale        String   @default("fr")
  // RGPD
  deletedAt            DateTime?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  members      AutosavWorkspaceMember[]
  invitations  AutosavInvitation[]
  integrations AutosavIntegration[]
  tickets      AutosavTicket[]
  auditLogs    AutosavAuditLog[]
  usageRecords AutosavUsageRecord[]

  @@index([deletedAt])
}

model AutosavWorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("agent")   // 'owner' | 'admin' | 'agent'
  createdAt   DateTime @default(now())

  workspace AutosavWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model AutosavInvitation {
  id          String   @id @default(cuid())
  workspaceId String
  email       String
  role        String   @default("agent")
  token       String   @unique
  expiresAt   DateTime
  invitedById String
  createdAt   DateTime @default(now())

  workspace AutosavWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User             @relation("AutosavInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model AutosavIntegration {
  id              String   @id @default(cuid())
  workspaceId     String
  type            String                            // 'shopify' | 'woocommerce' | 'gmail' | 'outlook' | 'ionos' | 'laposte'
  status          String   @default("disconnected") // 'connected' | 'disconnected' | 'error'
  // Config chiffrée AES-256-GCM via @47ng/cloak (à brancher quand on aura la masterkey)
  encryptedConfig String
  lastSyncAt      DateTime?
  lastSyncError   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace AutosavWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, type])
}

model AutosavTicket {
  id              String   @id @default(cuid())
  workspaceId     String
  externalId      String                            // UID IMAP, ID Gmail, etc.
  channel         String                            // 'email' | 'chat' | 'instagram'
  customerEmail   String
  customerName    String?
  subject         String
  body            String
  status          String   @default("pending")      // 'pending' | 'drafted' | 'sent' | 'resolved' | 'spam'
  priority        String   @default("medium")       // 'low' | 'medium' | 'high'
  category        String   @default("general")      // 'order' | 'return' | 'shipping' | 'complaint' | 'general'
  starred         Boolean  @default(false)
  unread          Boolean  @default(true)
  snoozeUntil     DateTime?
  archivedAt      DateTime?
  resolvedAt      DateTime?

  // Order context (auto-détecté)
  detectedOrderId String?
  orderStatus     String?                           // 'En transit', 'Livré', etc.
  orderEta        String?                           // 'Demain entre 10h-13h'
  orderTracking   String?

  assignedToId    String?
  receivedAt      DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace AutosavWorkspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  replies   AutosavTicketReply[]
  notes     AutosavTicketNote[]

  @@unique([workspaceId, externalId])
  @@index([workspaceId, status])
  @@index([workspaceId, customerEmail])
  @@index([workspaceId, receivedAt])
  @@index([workspaceId, starred])
}

// ============================================================
// AUTOSAV — notes internes sur les tickets (équipe only)
// ============================================================

model AutosavTicketNote {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    AutosavTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  body      String
  authorId  String?
  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
}

model AutosavTicketReply {
  id            String   @id @default(cuid())
  ticketId      String
  draftedBy     String                              // 'ai' | userId
  sentBody      String
  aiModel       String?                             // 'claude-sonnet' | 'gemini-flash'
  inputTokens   Int?
  outputTokens  Int?
  costCents     Int?
  isMetered     Boolean  @default(false)            // true si au-delà du quota = facturable
  userId        String?
  sentAt        DateTime @default(now())

  ticket AutosavTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([ticketId])
}

model AutosavAuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String?
  action      String                                // 'workspace.create' | 'integration.connect' | 'ticket.reply.send' | etc.
  target      String?                               // ID de la ressource ciblée
  metadata    Json?
  ipHash      String?
  createdAt   DateTime @default(now())

  workspace AutosavWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([action])
}

model AutosavUsageRecord {
  id                  String   @id @default(cuid())
  workspaceId         String
  ticketReplyId       String?
  quantity            Int      @default(1)
  stripeUsageRecordId String?
  reportedAt          DateTime?
  createdAt           DateTime @default(now())

  workspace AutosavWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, reportedAt])
}

// ============================================================
// AUTHENTIFICATION — tokens temporaires (email verif, 2FA, reset)
// ============================================================

model AuthToken {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Type du token :
  //   'email_verify' — lien envoyé après inscription, expire 24h
  //   'password_reset' — lien envoyé après "mot de passe oublié", expire 1h
  //   'totp_email' — code 6 chiffres pour la 2FA email, expire 10 min
  type        String

  // Hash SHA-256 du token (jamais en clair en base, comme pour les passwords).
  // Pour les codes 2FA : on hash le code 6 chiffres aussi.
  tokenHash   String   @unique

  // Métadonnées de contexte (IP du demandeur, user-agent) pour audit anti-fraude.
  ipHash      String?
  userAgent   String?

  expiresAt   DateTime
  usedAt      DateTime?                              // null = pas encore utilisé. One-shot.

  createdAt   DateTime @default(now())

  @@index([userId, type])
  @@index([expiresAt])
}

// ============================================================
// AUTHENTIFICATION — comptes OAuth liés (Google, Apple)
// ============================================================

model OAuthAccount {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider        String                              // 'google' | 'apple'
  providerUserId  String                              // sub du token OAuth (identifiant unique côté provider)
  email           String                              // email tel que retourné par le provider (info, peut différer)

  accessToken     String?                             // optionnel : on n'en a pas vraiment besoin après login
  refreshToken   String?
  expiresAt       DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([provider, providerUserId])
  @@index([userId])
}

// ============================================================
// AUTHENTIFICATION — audit des tentatives de connexion
// ============================================================

model LoginLog {
  id            String   @id @default(cuid())
  userId        String?                              // null si l'email n'existe pas (tentative phishing)
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email         String                               // email tenté (toujours stocké pour audit)
  success       Boolean
  failureReason String?                              // 'bad_password' | 'email_not_verified' | 'locked' | 'disabled' | 'no_account' | 'ip_blocked' | '2fa_failed'

  ipHash        String                               // SHA-256 (RGPD)
  userAgent     String?
  method        String                               // 'password' | 'google' | 'apple' | '2fa'

  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([ipHash, createdAt])
}

// ============================================================
// AUTHENTIFICATION — rate limit IP (blocage temporaire)
// ============================================================

model IpBlock {
  id           String   @id @default(cuid())
  ipHash       String   @unique
  reason       String                                 // 'login_brute_force' | 'register_spam' | 'manual'
  attemptCount Int      @default(0)
  blockedUntil DateTime                               // expire à cette date, après quoi on peut nettoyer
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([blockedUntil])
}

// ============================================================
// AFFILIATION — commissions générées (one-shot + recurring)
// ============================================================

model AffiliateCommission {
  id              String   @id @default(cuid())
  affiliateId     String
  affiliate       User     @relation("AffiliateCommissions", fields: [affiliateId], references: [id], onDelete: Cascade)

  referredUserId  String
  referredUser    User     @relation("ReferredCommissions", fields: [referredUserId], references: [id], onDelete: Cascade)

  type            String                            // 'onetime' (1er mois 100%) | 'recurring' (mois 2+, 5/10/15%)
  amount          Float                             // montant en euros (toujours positif)
  status          String   @default("pending")      // 'pending' | 'confirmed' | 'paid' | 'cancelled'

  // Mois de la souscription du filleul concerné par cette commission.
  // 1 = premier mois (toujours type=onetime), 2+ = type=recurring.
  periodMonth     Int?

  // Snapshot du plan + taux au moment du calcul (pour audit).
  affiliatePlanAtTime String?
  commissionRate      Float?                        // ex: 0.05, 0.10, 0.15 (null pour onetime)
  referredPlanAtTime  String?

  // Lien vers le virement Stripe Connect (rempli quand status passe à 'paid').
  stripePayoutId  String?
  payoutId        String?
  payout          AffiliatePayout? @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  // Source du déclenchement (audit / debugging webhooks Stripe).
  stripeInvoiceId String?

  // Flag anti-fraude : commission auto-cancelled avec note interne.
  flaggedReason   String?                           // ex: 'self_referral', 'same_ip_signup', 'manual_review'

  createdAt       DateTime @default(now())
  confirmedAt     DateTime?                         // posé à createdAt + 15 jours (délai de remboursement)
  paidAt          DateTime?                         // posé quand le virement Stripe Connect réussit

  @@index([affiliateId, status])
  @@index([referredUserId])
  @@index([status, confirmedAt])
}

// ============================================================
// AFFILIATION — clics enregistrés (tracking + anti-fraude)
// ============================================================

model AffiliateClick {
  id              String   @id @default(cuid())
  affiliateCode   String                            // pas une FK : on garde l'historique même si le code est régénéré
  ipHash          String                            // SHA-256 de l'IP, jamais en clair
  userAgent       String?
  referrer        String?
  converted       Boolean  @default(false)          // true si visiteur s'inscrit ensuite avec ce code
  convertedUserId String?                           // userId du filleul issu de ce clic
  createdAt       DateTime @default(now())

  @@index([affiliateCode, createdAt])
  @@index([affiliateCode, ipHash, createdAt])       // déduplication 24h same-IP
}

// ============================================================
// AFFILIATION — virements groupés mensuels
// ============================================================

model AffiliatePayout {
  id                  String   @id @default(cuid())
  affiliateId         String
  affiliate           User     @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  amount              Float                         // total versé en euros
  status              String   @default("pending")  // 'pending' | 'processing' | 'paid' | 'failed'
  stripeTransferId    String?                       // ID du Stripe Transfer / Payout
  failureReason       String?

  // Période couverte (informationnelle, pour l'email récap).
  periodStart         DateTime
  periodEnd           DateTime

  commissions         AffiliateCommission[]

  createdAt           DateTime @default(now())
  paidAt              DateTime?

  @@index([affiliateId, createdAt])
}

// ============================================================
// ORDERS — commandes passées via Sourcey (avec réduction selon plan)
// ============================================================

model Order {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  supplierName        String
  productDescription  String
  grossAmount         Int                              // montant fournisseur brut en €
  discountPct         Int                              // % de réduction (0/5/10/15)
  savedAmount         Int                              // € économisés
  netAmount           Int                              // € réellement payés par le client
  planAtOrder         String                           // plan actif au moment de la commande (free/essential/pro/premium)

  status              String   @default("pending")     // 'pending' | 'confirmed' | 'shipped' | 'delivered' | 'cancelled'

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId, createdAt])
}

// ============================================================
// BRIEF — formulaire de demande de sourcing soumis par le client
// ============================================================

model Brief {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Produit
  productName     String                           // Ex: "T-shirt premium coton bio"
  productType     String?                          // Ex: "textile", "electronique", "deco"
  description     String                           // Description libre + spécifications

  // Quantité & prix
  targetQuantity  String                           // Ex: "100", "500-1000", "MOQ minimum"
  targetPrice     String?                          // Ex: "5€/unité", "à voir selon qualité"
  targetDelivery  String?                          // Ex: "3 semaines", "avant Noël"

  // Pièces jointes
  referenceImages String?                          // JSON array d'URLs (uploads ou liens)
  inspirationUrl  String?                          // URL Alibaba / AliExpress / produit similaire

  // Workflow
  status          String   @default("new")         // 'new' | 'in-review' | 'supplier-contacted' | 'quote-ready' | 'ordered' | 'completed' | 'cancelled'
  internalNotes   String?                          // Notes Sourcey team (pas visible client)

  // Rich form payload — toutes les réponses du formulaire 6 sections en JSON
  // (profil, objectifs, projet, sourcing, références, contact).
  // Les champs colonne ci-dessus (productName, description...) sont remplis
  // par mapping depuis ce JSON pour affichage admin / listings.
  data            Json?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status])
}

model Conversation {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                String                                 // 'support' | 'agent'
  agentId             String?                                // slug of static agent if type='agent'
  agentName           String?                                // denormalized cache
  agentCity           String?
  agentAvatarUrl      String?
  sourcingRequestId   String?                                // optional link to a sourcing request
  title               String?
  lastMessagePreview  String?
  lastMessageAt       DateTime  @default(now())
  unreadByUser        Int       @default(0)
  unreadByCounterpart Int       @default(0)
  archivedAt          DateTime?
  createdAt           DateTime  @default(now())
  messages            Message[]

  @@index([userId, lastMessageAt])
}

model Message {
  id                  String       @id @default(cuid())
  conversationId      String
  conversation        Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderType          String                                  // 'user' | 'agent' | 'support' | 'system'
  senderId            String?                                 // userId if 'user', null otherwise
  senderUser          User?        @relation(fields: [senderId], references: [id], onDelete: SetNull)
  content             String
  attachments         String?                                 // JSON array of { url, name?, annotations?: [{id,x,y,comment}] }
  translatedContent   String?                                 // JSON {fr, zh}
  readByUserAt        DateTime?
  readByCounterpartAt DateTime?
  createdAt           DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ============================================================
// PRODUCT CATALOG — Sourcey-vetted catalog, each product has an agent
// ============================================================

model Product {
  id             String           @id @default(cuid())
  slug           String           @unique
  title          String
  shortPitch     String
  description    String
  category       String
  subcategory    String?
  images         String                                 // JSON array of URLs (first = main)
  agentSlug      String
  agentName      String                                 // denormalized
  agentCity      String                                 // denormalized
  agentAvatarUrl String                                 // denormalized
  priceTiers     String                                 // JSON [{minQty, unitPrice}]
  samplePrice    Int?
  currency       String           @default("EUR")
  moq            Int
  leadTimeDays   Int
  material       String?
  origin         String
  certifications String?                                // JSON array
  customizable   Boolean          @default(false)
  customOptions  String?                                // JSON array of strings
  sourcedTimes   Int              @default(0)
  rating         Float?
  reviewCount    Int              @default(0)
  featured       Boolean          @default(false)
  isNew          Boolean          @default(false)
  createdAt      DateTime         @default(now())
  requests       ProductRequest[]

  @@index([category, featured])
  @@index([agentSlug])
}

model ProductRequest {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type           String                              // 'quote' | 'sample'
  quantity       Int?
  message        String?
  conversationId String?
  status         String   @default("new")
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
}

// ============================================================
// PREMIUM SERVICES — Photoshoot, Packaging, Logo / Branding
// ============================================================

model ServiceOrder {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String                              // 'photoshoot' | 'packaging' | 'logo'
  tier            String                              // 'basic' | 'standard' | 'premium'
  brief           String
  references      String?                             // JSON array of URLs (mood board / inspiration)
  assignedAgentId String?                             // slug from static agents data
  status          String   @default("awaiting_quote") // awaiting_quote | quoted | in_progress | revisions | delivered | cancelled
  estimatedPrice  Int                                 // euros
  finalPrice      Int?
  deliverableUrl  String?                             // URL to final deliverable when status=delivered
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, createdAt])
}
